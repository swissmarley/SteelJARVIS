# Environment variables for JARVIS
# Copy this to .env and fill in your values

# Required: Anthropic Claude API key for AI reasoning
ANTHROPIC_API_KEY=

# Optional: OpenAI API key for embeddings fallback or alternative TTS/STT
OPENAI_API_KEY=

# Optional: Search API (e.g., Google Custom Search, Brave, SearXNG)
SEARCH_API_KEY=
SEARCH_ENGINE_ID=